# ===== Banco de dados =====
DATABASE_URL="postgresql://postgres:senha@db.xxxxx.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:senha@db.xxxxx.supabase.co:5432/postgres"

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# ===== App =====
NEXT_PUBLIC_APP_URL="https://sosservicos.com.br"
NODE_ENV="production"

# ===== Push notifications (VAPID) =====
# Gerar com: npm run vapid:generate
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@sosservicos.com.br"

# ===== Rate limit / anti-spam =====
RATE_LIMIT_ENABLED="true"
HONEYPOT_FIELD_NAME="website_confirm"

# ===== Cron / jobs internos =====
CRON_SECRET="defina-um-segredo-aleatorio-aqui"

# ===== LGPD =====
DPO_EMAIL="privacidade@sosservicos.com.br"

# ===== Analytics (opcional) =====
NEXT_PUBLIC_GA_ID=""
